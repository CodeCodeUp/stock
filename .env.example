# Database (required)
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=stock

# Ports (optional, defaults shown)
FRONTEND_PORT=80
BACKEND_PORT=8080
DATA_API_PORT=5000

# Scheduler (optional)
SCHEDULER_TIMEZONE=Asia/Shanghai
ENABLE_IMPORTER=true
ENABLE_PRICE_TRACKING=true
