# Database (required, used by docker compose and local direct startup)
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=stock
DB_USE_SSL=false
DB_ALLOW_PUBLIC_KEY_RETRIEVAL=true

# Ports (optional, defaults shown)
FRONTEND_PORT=80
BACKEND_PORT=8080
DATA_API_PORT=5000

# Backend CORS for local frontend dev
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend dev proxy target (optional, defaults to http://localhost:${BACKEND_PORT})
VITE_DEV_PROXY_TARGET=http://localhost:8080

# Mirrors for Docker build downloads (recommended in mainland China)
DOCKER_MIRROR=docker.m.daocloud.io
NPM_REGISTRY=https://registry.npmmirror.com
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn

# Scheduler (optional)
ENABLE_SCHEDULER=true
SCHEDULER_TIMEZONE=Asia/Shanghai
ENABLE_IMPORTER=true
ENABLE_PRICE_TRACKING=true

# Import / tracking tuning (optional)
IMPORT_LOOKBACK_DAYS=7
PRICE_TRACKING_MAX_WORKERS=4
PRICE_TRACKING_RETRY_TIMES=3
PRICE_TRACKING_RETRY_DELAY_SECONDS=1
DB_WRITE_BATCH_SIZE=2000

# Logging (optional)
LOG_LEVEL=INFO

# External data API retry (optional)
AKSHARE_RETRY_TIMES=3
AKSHARE_RETRY_DELAY_SECONDS=1

# Eastmoney kline throttle (optional, per process)
EASTMONEY_KLINE_INTERVAL_SECONDS=10
